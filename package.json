{
  "name": "www",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build:html": "html-minifier-terser --collapse-whitespace --remove-comments --minify-css true --minify-js true -o dist/index.html index.html",
    "build:css": "cleancss -o dist/styles.css styles.css",
    "build:js": "terser scripts.js -c -m -o dist/scripts.js",
    "build": "npm run clean && mkdir -p dist && npm run build:css && npm run build:js && npm run build:html && cp CNAME dist/"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.36.0"
  }
}
